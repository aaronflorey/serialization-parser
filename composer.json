{
    "name": "mochaka/serialization-parser",
    "description": "This is my package serialization-parser",
    "keywords": [
        "Mochaka",
        "laravel",
        "serialization-parser"
    ],
    "homepage": "https://github.com/mochaka/serialization-parser",
    "license": "MIT",
    "authors": [
        {
            "name": "Aaron Florey",
            "email": "aaron@buckhamduffy.com",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.0",
        "illuminate/contracts": "^10.0||^11.0||^12.0|^13.0",
        "spatie/laravel-package-tools": "^1.16"
    },
    "require-dev": {
        "buckhamduffy/coding-standards": "^7|^8",
        "captainhook/hook-installer": "^1.0",
        "larastan/larastan": "^2.9||^3.0",
        "laravel/framework": "^12|^13",
        "nunomaduro/collision": "^8.1.1||^7.10.0",
        "orchestra/testbench": "^10.0.0||^9.0.0||^8.22.0",
        "phpstan/extension-installer": "^1.3||^2.0",
        "phpstan/phpstan": "^2.1",
        "phpstan/phpstan-deprecation-rules": "^1.1||^2.0",
        "phpunit/phpunit": "^11"
    },
    "autoload": {
        "psr-4": {
            "Mochaka\\SerializationParser\\": "src/",
            "Mochaka\\SerializationParser\\Database\\Factories\\": "database/factories/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Mochaka\\SerializationParser\\Tests\\": "tests/",
            "Workbench\\App\\": "workbench/app/"
        }
    },
    "scripts": {
        "post-autoload-dump": "@composer run prepare",
        "prepare": "@php vendor/bin/testbench package:discover --ansi",
        "analyse": "vendor/bin/phpstan analyse",
        "test": "vendor/bin/pest",
        "test-coverage": "vendor/bin/pest --coverage",
        "format": "vendor/bin/pint"
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "captainhook/hook-installer": true,
            "pestphp/pest-plugin": true,
            "phpstan/extension-installer": true
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Mochaka\\SerializationParser\\SerializationParserServiceProvider"
            ],
            "aliases": {
                "SerializationParser": "Mochaka\\SerializationParser\\Facades\\SerializationParser"
            }
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
